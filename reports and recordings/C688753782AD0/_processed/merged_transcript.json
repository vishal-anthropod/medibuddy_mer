      "start_timestamp": "0:27",
      "end_timestamp": "0:28",
      "call_index": 1
    },
    {
      "segment_id": "call1_11",
      "text": "So let's start. This is Dr. Nilofar speaking from Tata AIA Life Insurance. And I am speaking with Mudit Mukesh Kamdar ji, right?",
      "speaker": "doctor",
      "start_timestamp": "0:30",
      "end_timestamp": "0:37",
