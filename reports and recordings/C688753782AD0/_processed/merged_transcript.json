      "start_timestamp": "0:38",
      "end_timestamp": "0:38",
      "call_index": 1
    },
    {
      "segment_id": "call1_13",
      "text": "Sir, this call is regarding your proposal, to move it forward.",
      "speaker": "doctor",
      "start_timestamp": "0:40",
      "end_timestamp": "0:44",
      "call_index": 1
    },
